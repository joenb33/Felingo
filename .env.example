# ElevenLabs — used only by: npm run generate:tts
#
# SECURITY (public repo)
# - Copy this file to `.env` and fill in values locally only.
# - `.env` is gitignored; never paste API keys into source files, issues, or commits.
# - Generated MP3s under public/audio/ are gitignored — build them locally, deploy to your server as needed.

ELEVENLABS_API_KEY=
# Voice ID from https://elevenlabs.io/app/voice-library (or your cloned voice)
ELEVENLABS_VOICE_ID=

# Optional — default: eleven_multilingual_v2
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
